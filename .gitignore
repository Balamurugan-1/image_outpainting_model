# Python
__pycache__/
*.py[cod]
*.egg-info/
.Python

# Virtual environment
.venv/
venv/
env/

# Training artifacts: checkpoints, logs, sample images, W&B offline runs.
# All regenerated by running training — never commit (can reach hundreds of GB).
workdir/
wandb/
*.log
*.ckpt

# Pretrained / model weight binaries — large, download separately (see README.md / details.md).
assets/
*.pth
*.pt
*.safetensors
*.bin

# Datasets — large and often license-restricted; place locally per details.md §7.
# Code under dataset/ (the loader classes) is kept; only data subfolders are ignored.
dataset/*
!dataset/*.py

# Evaluation outputs (generated images, metrics scratch dirs) — keep only the scripts.
eval_dir/*
!eval_dir/*.py

# Ad-hoc sampling outputs
sample_outputs/

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp

improvement.md